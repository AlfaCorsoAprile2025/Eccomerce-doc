openapi: 3.0.3
info:
  title: Order Service API
  description: >
    API per la gestione degli ordini. 
  version: 1.0.0

servers:
  - url: https://localhost:8082/orders
    description: Order Service Server

tags:
  - name: Ordini Utente
    description: Operazioni disponibili per i clienti sui propri ordini.
  - name: Gestione Ordini (Admin)
    description: Operazioni amministrative globali.

security:
  - Auth: []

paths:
  /ordini:
    get:
      tags:
        - Ordini Utente
        - Gestione Ordini (Admin)
      summary: Visualizzazione Lista Ordini (UC-09)
      description: >
        Restituisce la lista degli ordini. 
        - **Cliente**: vede solo i propri ordini.
        - **Admin**: vede tutti gli ordini del sistema.
      parameters:
        - name: page
          in: query
          schema:
            type: integer
            default: 1
        - name: status
          in: query
          description: Filtra per stato (es. In lavorazione, Spedito)
          schema:
            $ref: '#/components/schemas/OrderStatus'
      responses:
        '200':
          description: Lista ordini recuperata con successo (paginata).
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/OrderListResponse'
        '401':
          $ref: '#/components/responses/Unauthorized'
        '500':
          $ref: '#/components/responses/InternalError'

  /ordini/search:
    post:
      tags:
        - Ordini Utente
        - Gestione Ordini (Admin)
      summary: Ricerca Avanzata Ordini
      description: >
        Permette ricerche complesse (range di date, filtri di prezzo, ordinamento). 
        I criteri sono flessibili e non richiedono una corrispondenza esatta.
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/OrderSearchRequest'
      responses:
        '200':
          description: Lista ordini recuperata con successo (paginata).
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/OrderListResponse'

  /ordini/filter:
    post:
      tags:
        - Gestione Ordini (Admin)
      summary: Filtro per Corrispondenza Esatta (Field Match)
      description: >
        Restituisce gli ordini che corrispondono esattamente ai valori forniti nel body.
        Se un campo è null o omesso, non viene considerato nel filtro.
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                match_criteria:
                  type: object
                  description: Campi per il matching esatto
                  properties:
                    customer_id: { type: string, example: "user-123" }
                    status: { type: string, example: "Spedito" }
                    total: { type: number, example: 99.99 }
                pagination:
                  type: object
                  properties:
                    limit: { type: integer, default: 20 }
                    offset: { type: integer, default: 0 }
      responses:
        '200':
          description: Ordini che corrispondono esattamente ai criteri
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/OrderSummary'
        '400':
          $ref: '#/components/responses/BadRequest'

  /ordini/{orderId}:
    get:
      tags:
        - Ordini Utente
      summary: Dettaglio Ordine
      description: Recupera le informazioni complete di un singolo ordine.
      parameters:
        - $ref: '#/components/parameters/OrderId'
      responses:
        '200':
          description: Dettaglio ordine.
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Order'
        '403':
          description: Accesso Negato (E2) - L'ordine non appartiene all'utente.
        '404':
          $ref: '#/components/responses/NotFound'
    put:
      tags:
        - Gestione Ordini (Admin)
      summary: Sostituzione Integrale Ordine
      description: >
        Sostituisce completamente l'ordine esistente con i nuovi dati forniti. 
        Utilizzare questo metodo per un aggiornamento "pesante" dell'ordine (es. cambio totale del carrello e indirizzo).
      parameters:
        - $ref: '#/components/parameters/OrderId'
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/OrderPutRequest'
      responses:
        '200':
          description: Ordine aggiornato con successo.
        '403':
          description: Non Autorizzato
          content:
              application/json:
                schema:
                    $ref: '#/components/schemas/Error'
        '422':
          description: Errore di validazione (E1 - Già spedito, E3 - Stock insufficiente).
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Error'
        '404':
          $ref: '#/components/responses/NotFound'

    patch:
      tags:
        - Ordini Utente
        - Gestione Ordini (Admin)
      summary: Modifica Ordine (UC-093M)
      description: >
        Permette la modifica di un ordine se non è ancora "Spedito".
        I clienti possono modificare solo l'indirizzo. Gli Admin possono modificare anche lo stato e le quantità.
      parameters:
        - $ref: '#/components/parameters/OrderId'
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/OrderUpdate'
      responses:
        '200':
          description: Ordine aggiornato con successo.
        '403':
          description: Non Autorizzato
          content:
              application/json:
                schema:
                    $ref: '#/components/schemas/Error'
        '422':
          description: Errore di validazione (E1 - Già spedito, E3 - Stock insufficiente).
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Error'
        '404':
          $ref: '#/components/responses/NotFound'

    delete:
      tags:
        - Ordini Utente
        - Gestione Ordini (Admin)
      summary: Annullamento Ordine (UC094M)
      description: Imposta lo stato dell'ordine su "Annullato" e ripristina lo stock.
      parameters:
        - $ref: '#/components/parameters/OrderId'
      responses:
        '204':
          description: Ordine annullato con successo.
        '400':
          description: Impossibile annullare l'ordine (es. già spedito).
        '404':
          $ref: '#/components/responses/NotFound'

components:
  parameters:
    OrderId:
      name: orderId
      in: path
      required: true
      schema:
        type: string
        format: uuid

  responses:
    BadRequest:
      description: Richiesta non valida.
    Unauthorized:
      description: Token mancante o non valido.
    NotFound:
      description: Ordine non trovato.
    InternalError:
      description: Errore del server.

  schemas:
    OrderSummary:
      type: object
      properties:
        id: { type: string, format: uuid }
        date: { type: string, format: date-time }
        total: { type: number, format: float }
        status: 
          $ref: '#/components/schemas/OrderStatus'
    OrderListResponse:
      type: object
      properties:
        items:
          type: array
          items:
            $ref: '#/components/schemas/OrderSummary'
        pagination:
          type: object
          properties:
            total_items:
              type: integer
              description: Numero totale di ordini trovati nel database.
              example: 154
            total_pages:
              type: integer
              description: Numero totale di pagine disponibili.
              example: 8
            current_page:
              type: integer
              description: La pagina corrente restituita.
              example: 1
            limit:
              type: integer
              description: Numero di elementi per pagina utilizzati.
              example: 20
    Order:
      allOf:
        - $ref: '#/components/schemas/OrderSummary'
        - type: object
          properties:
            customer_id: { type: string }
            shipping_address:
              $ref: '#/components/schemas/Address'
            items:
              type: array
              items:
                $ref: '#/components/schemas/OrderItem'

    OrderItem:
      type: object
      properties:
        productId: { type: string, format: uuid }
        name: { type: string }
        quantity: { type: integer, minimum: 1 }
        price_unit: { type: number }

    Address:
      type: object
      required: [street, city, zip_code]
      properties:
        full_name: { type: string }
        street: { type: string }
        city: { type: string }
        zip_code: { type: string }
        province: { type: string }

    OrderUpdate:
      type: object
      description: Campi modificabili. Le restrizioni di ruolo sono applicate lato server.
      properties:
        shipping_address:
          $ref: '#/components/schemas/Address'
        status:
          type: string
          description: (Solo Admin) Nuovo stato dell'ordine.
        items:
          type: array
          description: (Admin/Cliente) Modifica quantità o rimozione prodotti.
          items:
            type: object
            properties:
              productId: { type: string, format: uuid }
              quantity: { type: integer }

    OrderSearchRequest:
          type: object
          properties:
            filters:
              type: object
              properties:
                date_range:
                  type: object
                  properties:
                    from: { type: string, format: date-time }
                    to: { type: string, format: date-time }
                price_range:
                  type: object
                  properties:
                    min: { type: number }
                    max: { type: number }
                status_list:
                  type: array
                  items:
                    type: string
                  description: "Cerca ordini che abbiano uno di questi stati (OR logic)"
            sort_by:
              type: string
              enum: [date_asc, date_desc, total_asc, total_desc]
              example: "date_desc"
            pagination:
              type: object
              properties:
                limit: { type: integer, default: 20 }
                offset: { type: integer, default: 0 }
    OrderStatus:
          type: string
          enum:
            - "In lavorazione"
            - "In preparazione"
            - "Spedito"
            - "Consegnato"
            - "Annullato"
          description: Stati possibili di un ordine nel sistema.

    OrderPutRequest:
      type: object
      required: [shipping_address, items]
      properties:
        shipping_address:
          $ref: '#/components/schemas/Address'
        items:
          type: array
          minItems: 1
          items:
            $ref: '#/components/schemas/OrderItem'
    Error:
      type: object
      properties:
        code: { type: string }
        message: { type: string }

  securitySchemes:
    Auth:
      type: http
      scheme: bearer
      bearerFormat: JWT